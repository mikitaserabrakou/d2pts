{
  "manifest_version": 3,
  "name": "D2PTS",
  "version": "1.0.2",
  "description": "Switch dota2protracker tab to selected hero in-game",
  "icons": {
    "96": "icons/icon-96.svg",
    "32": "icons/icon-32.svg"
  },
  "action": {
    "default_icon": "icons/icon-96.svg"
  },
  "permissions": ["tabs"],
  "host_permissions": [
    "https://localhost:5005/*",
    "*://dota2protracker.com/hero/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "D2PTS@nvcb16",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
